{
  "manifest_version": 3,
  "name": "HorseMed Auto-Fill – StudIT.net",
  "version": "1.1",
  "description": "Auto-fills medication plans and applies with pre-filled data",
  "permissions": [],
  "host_permissions": ["https://*.studit.net/*"],
  "web_accessible_resources": [
    {
      "resources": ["config.json"],
      "matches": ["https://*.studit.net/*"]
    }
  ],
  "content_scripts": [
    {
      "matches": ["https://*.studit.net/*"],
      "js": ["content.js"],
      "run_at": "document_end",
      "all_frames": false
    }
  ]
}